{
  "name": "@stackra/nestjs-queue",
  "version": "1.0.0",
  "description": "NestJS queue — bridges @nestjs/bullmq into @stackra/ts-queue. BullMQ-flavored QueueService + IQueueConnection adapter for cross-stack dispatch.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "keywords": [
    "stackra",
    "nestjs",
    "queue",
    "bullmq",
    "redis",
    "job-queue",
    "worker",
    "background-jobs"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {},
  "peerDependencies": {
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "bullmq": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/testing": "^11.0.1",
    "@stackra/contracts": "github:stackra-inc/contracts#main",
    "@stackra/tsup-config": "^1.0.12",
    "@types/node": "^25.9.1",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
